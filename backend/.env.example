# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=myphotolife

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Storage (S3-compatible - Cloudflare R2 recommended)
STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_ORIGINALS=myphotolife-originals
STORAGE_BUCKET_OPTIMIZED=myphotolife-optimized
STORAGE_PUBLIC_URL=https://cdn.myphotolife.com

# Image Processing
IMAGE_QUALITY=80
IMAGE_MAX_WIDTH=2048
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=300

# Payment Gateway (Pix)
PIX_GATEWAY_URL=
PIX_GATEWAY_API_KEY=
PIX_GATEWAY_WEBHOOK_SECRET=

# CORS
CORS_ORIGIN=http://localhost:3000
