# ============================================================
# MyPhotoLife - Backend Configuration
# Copie este arquivo como .env e preencha os valores
# ============================================================

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=myphotolife

# JWT
# OBRIGATÓRIO: mínimo 32 caracteres em produção
JWT_SECRET=change-me-to-a-long-random-string-with-32-chars-min
JWT_EXPIRES_IN=7d

# Storage (S3-compatible - Cloudflare R2 recomendado)
STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_ORIGINALS=myphotolife-originals
STORAGE_BUCKET_OPTIMIZED=myphotolife-optimized
STORAGE_PUBLIC_URL=https://cdn.myphotolife.com

# Image Processing
IMAGE_QUALITY=80
IMAGE_MAX_WIDTH=2048
THUMBNAIL_WIDTH=400
THUMBNAIL_HEIGHT=300

# Payment Gateway (Pix)
# URL base do gateway de pagamento (ex: Asherah, GerenciaNet, etc.)
PIX_GATEWAY_URL=
PIX_GATEWAY_API_KEY=
# Segredo compartilhado para validar webhooks (HMAC-SHA256)
PIX_GATEWAY_WEBHOOK_SECRET=

# Email (SMTP para formulário de contato)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@myphotolife.com

# CORS
CORS_ORIGIN=http://localhost:3000
