# API Backend Fastify (obrigatório em produção)
# URL do backend para os rewrites do Next.js
API_URL=http://localhost:3001

# URL pública do frontend (usada para metadados, links, SEO)
# Em produção: https://myphotolife.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL do site (legado - use NEXT_PUBLIC_APP_URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (opcional - disponível para funcionalidades futuras)
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon-publica

# Supabase Service Role (apenas server-side - NUNCA expor no cliente)
# SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role
